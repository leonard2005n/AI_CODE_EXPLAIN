<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.leonard2005n.aicodeexplain</id>
    <name>AI_CODE_EXPLAIN</name>
    <vendor>leonard2005n</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.leonard2005n.aicodeexplain.toolWindow.MyToolWindowFactory"
                    id="AI Explainer"
                    anchor="right"
                    icon="/icons/iconAi.svg" /> <postStartupActivity implementation="com.github.leonard2005n.aicodeexplain.startup.MyProjectActivity" />
    </extensions>

    <actions>
        <group id="AiCodeActionsGroup" text="AI Code Tools" popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>

            <action id="ExplainCodeAiAction"
                    class="com.github.leonard2005n.aicodeexplain.actions.ExplainCodeAction"
                    text="Explain Code"
                    description="Asks AI to explain the selected code"/>

            <action id="FindBugsAiAction"
                    class="com.github.leonard2005n.aicodeexplain.actions.DebugCodeAction"
                    text="Find Bugs"
                    description="Asks AI to find potential bugs in the code"/>

            <action id="RefactorCodeAiAction"
                    class="com.github.leonard2005n.aicodeexplain.actions.RefactorCodeAction"
                    text="Refactor Code"
                    description="Asks AI to simplify and refactor the code"/>

            <action id="GenerateTestsAiAction"
                    class="com.github.leonard2005n.aicodeexplain.actions.GenerateTestsAction"
                    text="Generate Tests"
                    description="Asks AI to generate unit tests for the code"/>
        </group>
    </actions>
</idea-plugin>
